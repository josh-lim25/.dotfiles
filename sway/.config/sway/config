for_window [app_id="dev.zed.Zed"] focus

# Start applications on login
exec firefox
exec kitty
exec obsidian
exec dunst &
exec wlsunset -S 05:30 -s 18:30 -t 3000
exec_always pkill kanshi; exec kanshi

# Fix screen sharing, also need ~/.zprofile
