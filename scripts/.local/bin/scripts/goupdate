#!/usr/bin/env bash
# Source: https://go.dev/doc/install
set -euo pipefail

# Get current and latest version
current_version=$(go version 2>/dev/null | cut -d' ' -f 3 || echo "none")
latest_release=$(curl -sSL "https://go.dev" | head -n 1)

if [[ "$current_version" == "$latest_release" ]]; then
    echo "The local Go version ${latest_release} is up-to-date."
    exit 0
else
    echo "Current Go version: ${current_version}. New release available: ${latest_release}."
fi

# Define paths
TARGET_DIR="${HOME}/apps"
release_file="${latest_release}.linux-amd64.tar.gz"

# Ensure target directory exists
mkdir -p "$TARGET_DIR"

# Create secure temporary working directory
tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

echo "Downloading https://go.dev/dl/$release_file ..."
curl -sSL -o "$tmp/$release_file" "https://go.dev/dl/$release_file"

echo "Extracting to temporary location..."
# Extract inside tmp to avoid overwriting anything prematurely
tar -C "$tmp" -xzf "$tmp/$release_file"

# Remove existing specific version folder if it exists to avoid conflicts
rm -rf "${TARGET_DIR}/${latest_release}"

# Move the newly extracted 'go' folder to its versioned name
mv "$tmp/go" "${TARGET_DIR}/${latest_release}"

# Update the symlink atomically
ln -sfn "${TARGET_DIR}/${latest_release}" "${TARGET_DIR}/go"

# Verify update
# Note: Ensure ${HOME}/apps/go/bin is at the front of your PATH variable
new_version=$("${TARGET_DIR}/go/bin/go" version | cut -d' ' -f 3)
echo "Successfully updated! Now local Go version is $new_version"
