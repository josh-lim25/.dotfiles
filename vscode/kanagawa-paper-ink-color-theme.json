    },
    "interface": {
      "foreground": "#8ea49e"
    },
    "enum": {
      "foreground": "#8ea49e"
    },
    "enumMember": {
      "foreground": "#b6927b"
    },
    "typeParameter": {
      "foreground": "#8ea49e"
    },
    "namespace": {
      "foreground": "#8ea49e"
    },
    "function": {
      "foreground": "#859fac"
    },
    "method": {
