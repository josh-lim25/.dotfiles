      "foreground": "#727169",
      "fontStyle": "italic"
    },
    "keyword": {
      "foreground": "#a292a3"
    },
    "operator": {
      "foreground": "#c4746e"
    },
    "string": {
      "foreground": "#8a9a7b"
    },
