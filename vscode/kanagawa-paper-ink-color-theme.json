  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#727169",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment doc",
      "scope": [
        "comment.block.documentation",
        "comment.documentation"
      ],
      "settings": {
        "foreground": "#717e67",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables / fields default",
      "scope": [
        "variable",
        "meta.variable",
        "variable.other",
        "variable.other.readwrite",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#DCD7BA"
      }
    },
    {
      "name": "Variable language (this/self)",
      "scope": [
        "variable.language",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#938AA9"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "variable.parameter.function"
      ],
      "settings": {
        "foreground": "#a6a69c"
      }
    },
    {
      "name": "Members / properties / fields",
      "scope": [
        "variable.other.member",
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#c4746e"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "variable.other.constant",
        "constant.other",
        "constant.other.caps"
      ],
      "settings": {
        "foreground": "#b6927b"
      }
    },
    {
      "name": "Constant language (bool/null/nil)",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.nil",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#b6927b"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#a292a3"
      }
    },
    {
      "name": "Characters / escapes",
      "scope": [
        "constant.character",
        "constant.character.escape",
        "constant.other.character-class"
      ],
      "settings": {
        "foreground": "#c4746e"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.template",
        "string.unquoted",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#8a9a7b"
      }
    },
    {
      "name": "String punctuation",
      "scope": [
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#8a9a7b"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "constant.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#c4746e"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.other",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.return",
        "keyword.control.default",
        "keyword.other.fn"
      ],
      "settings": {
        "foreground": "#a292a3"
      }
    },
    {
      "name": "Operators / keyword operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.relational",
        "keyword.operator.bitwise",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#c4746e"
      }
    },
    {
      "name": "Operator words (in/and/or)",
      "scope": [
        "keyword.operator.word",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#a292a3"
      }
    },
    {
      "name": "Storage (var/const/func/type kw)",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier",
        "storage.type.function",
        "keyword.declaration",
        "keyword.var",
        "keyword.const",
        "keyword.function",
        "keyword.struct",
        "keyword.type",
        "keyword.enum",
        "keyword.interface"
      ],
      "settings": {
        "foreground": "#a292a3"
      }
    },
    {
      "name": "Functions / methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "meta.function-call.generic",
        "variable.function",
        "entity.name.function.member",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#859fac"
      }
    },
    {
      "name": "Function macros / preproc",
      "scope": [
        "entity.name.function.macro",
        "meta.preprocessor",
        "keyword.control.directive",
        "entity.name.function.preprocessor"
      ],
      "settings": {
        "foreground": "#c4746e"
      }
    },
    {
      "name": "Types / classes / structs",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.type.class",
        "entity.name.type.struct",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "support.type",
        "support.class",
        "entity.other.inherited-class",
        "meta.type.name",
        "storage.type.primitive",
        "entity.name.type.primitive"
      ],
      "settings": {
        "foreground": "#8ea49e"
      }
    },
    {
      "name": "Type builtins / annotations",
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "entity.name.type.parameter",
        "storage.type.generic"
      ],
      "settings": {
        "foreground": "#8ea49e"
      }
    },
    {
      "name": "Namespaces / modules / packages",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.package",
        "storage.modifier.package",
        "support.module",
        "variable.other.namespace"
      ],
      "settings": {
        "foreground": "#8ea49e"
      }
    },
    {
      "name": "Attributes / decorators / annotations",
      "scope": [
        "entity.name.attribute-name",
        "meta.attribute",
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "storage.type.annotation",
        "meta.annotation",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#c4b28a"
      }
    },
    {
      "name": "Labels",
      "scope": [
