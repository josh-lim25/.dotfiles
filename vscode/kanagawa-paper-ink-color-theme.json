    "property.readonly": {
      "foreground": "#b6927b"
    },
    "member": {
      "foreground": "#c4746e"
    },
    "label": {
      "foreground": "#c4b28a"
    },
    "decorator": {
      "foreground": "#c4b28a"
    },
    "*.declaration": {},
    "selfKeyword": {
      "foreground": "#938AA9"
    },
    "builtinType": {
      "foreground": "#8ea49e"
    },
    "*.deprecated": {
      "fontStyle": "strikethrough"
    },
    "namespace.go": {
      "foreground": "#8ea49e"
    },
    "operator.go": {
      "foreground": "#c4746e"
    }
